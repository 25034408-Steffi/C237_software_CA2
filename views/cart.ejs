<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
  <%- include("partials/navbar") %>

  <div class="container mt-4 mb-5">
    <div class="d-flex align-items-center mb-3">
        <i class="bi bi-cart3 me-2" style="font-size:2rem; color: var(--terracotta);"></i>
        <h1 class="menu-text card-title mb-0" style="font-size:1.8rem;">Your Cart</h1>
    </div>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger py-2 px-3 my-2">
            <% errors.forEach(function(error) { %>
                <p class="mb-0"><%= error %></p>
            <% }); %>
        </div>
    <% } %>
    <% if (messages && messages.length > 0) { %>
        <div class="alert alert-success py-2 px-3 my-2">
            <% messages.forEach(function(message) { %>
                <p class="mb-0"><%= message %></p>
            <% }); %>
        </div>
    <% } %>

    <% if (cartItems.length === 0) { %>
        <div class="card food-card p-4 text-center mt-3">
            <p class="menu-text fs-5 mb-3">Your cart is empty.</p>
            <div>
                <a href="/menu" class="btn btn-primary"><i class="bi bi-journal-richtext me-1"></i> Browse Menu</a>
            </div>
        </div>
    <% } else { %>
        <div class="table-responsive mt-3">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th class="menu-text">Item</th>
                        <th class="menu-text">Price</th>
                        <th class="menu-text">Quantity</th>
                        <th class="menu-text text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <% cartItems.forEach(item => { %>
                        <tr>
                            <td class="menu-text"><strong><%= item.name %></strong></td>
                            <td class="menu-text">$<%= Number(item.price).toFixed(2) %></td>
                            <td class="menu-text"><%= item.quantity %></td>
                            <td class="menu-text text-end">$<%= item.itemTotal %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <a href="/menu" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to Menu</a>
            <div class="text-end">
                <h2 class="menu-text mb-3">Total: $<%= total %></h2>
                <form action="/checkout" method="POST">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-credit-card me-1"></i> Checkout
                    </button>
                </form>
            </div>
        </div>
    <% } %>
  </div>
</body>
</html>