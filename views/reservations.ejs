<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservations | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include("partials/navbar") %>

  <div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-calendar-event me-2" style="font-size:2rem; color: var(--terracotta);"></i>
                <h1 class="menu-text card-title mb-0" style="font-size:1.8rem;">Book a Table</h1>
            </div>

            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger py-2 px-3 my-2">
                    <% errors.forEach(function(error) { %>
                        <p class="mb-0"><%= error %></p>
                    <% }); %>
                </div>
            <% } %>
            <% if (messages && messages.length > 0) { %>
                <div class="alert alert-success py-2 px-3 my-2">
                    <% messages.forEach(function(message) { %>
                        <p class="mb-0"><%= message %></p>
                    <% }); %>
                </div>
            <% } %>

            <div class="card food-card p-4 mb-4">
                <form action="/reservations" method="POST">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="reservation_date" class="form-label menu-text">Date</label>
                            <input type="date" id="reservation_date" name="reservation_date" class="form-control" required>
                        </div>
                        <div class="col-md-4">
                            <label for="reservation_time" class="form-label menu-text">Time</label>
                            <input type="time" id="reservation_time" name="reservation_time" class="form-control" required>
                        </div>
                        <div class="col-md-4">
                            <label for="party_size" class="form-label menu-text">Party Size</label>
                            <input type="number" id="party_size" name="party_size" min="1" max="20" placeholder="Guests" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-4 w-100">
                        <i class="bi bi-bookmark-check me-1"></i> Reserve Now
                    </button>
                </form>
            </div>

            <h2 class="menu-text card-title mb-3" style="font-size:1.4rem;">Your Bookings</h2>
            <% if (reservations.length === 0) { %>
                <p class="menu-text text-muted">No reservations found.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th class="menu-text">Date</th>
                                <th class="menu-text">Time</th>
                                <th class="menu-text">Party Size</th>
                                <th class="menu-text">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reservations.forEach(res => { %>
                                <tr>
                                    <td class="menu-text"><%= res.reservation_date %></td>
                                    <td class="menu-text"><%= res.reservation_time %></td>
                                    <td class="menu-text"><%= res.party_size %> guests</td>
                                    <td><span class="badge bg-success"><%= res.status %></span></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
  </div>
</body>
</html>