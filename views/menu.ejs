<!DOCTYPE html>
<html>
<head>
    <title>Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <%- include("partials/foodNav") %>
  <div class="container mt-5">
    <div class="row">
      <div class="col-lg-9">
          <div class="row row-cols-1 row-cols-lg-2 g-4">
          <% for (let i=0; i < menuItems.length; i++){ %>
            <div class="col">

            <div class="card food-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h1 class="menu-text card-title"><%= menuItems[i].name %></h1>
                    <h2 class="menu-text">$<%= menuItems[i].price %></h2>
                    <p class="menu-text card-text"><%= menuItems[i].description %></p>
                  </div>
                  <img src="/images/<%= menuItems[i].image %>" alt="<%= menuItems[i].name %>" class="card-img-right">
                </div>
              </div>
            </div>
              <% } %>
        </div>
      </div>
      <div class="col-lg-3 d-none d-lg-block">
        <div style="background-color: grey; height:500px">

        </div>
      </div>
    </div>

  </div>
</body>