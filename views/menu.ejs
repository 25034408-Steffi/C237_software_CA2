<!DOCTYPE html>
<html>
<head>
    <title>Menu | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <%- include("partials/foodNav") %>
  <div class="container mt-4 mb-5">
    <div class="row">
      <div class="col-lg-9">
        <h1 class="menu-text card-title mb-3" style="font-size:1.6rem;"><%= activeCategory %></h1>
        <div class="row row-cols-1 row-cols-lg-2 g-4">
          <% for (let i=0; i < menuItems.length; i++){ %>
            <div class="col">
              <div class="card food-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <div class="d-flex justify-content-between align-items-start">
                      <h1 class="menu-text card-title"><%= menuItems[i].name %></h1>
                      <a href="/favourites/toggle/<%= menuItems[i].menu_item_id %>?back=menu&category=<%= encodeURIComponent(activeCategory === 'Favourites' ? 'favourites' : activeCategory) %>"
                         class="fav-toggle text-decoration-none fs-5 ms-2" title="Add or remove favourite"
                         <% if (activeCategory === 'Favourites') { %>data-remove-on-unfav="true"<% } %>>
                        <i class="bi <%= menuItems[i].is_fav ? 'bi-heart-fill text-danger' : 'bi-heart text-secondary' %>"></i>
                      </a>
                    </div>
                    <h2 class="menu-text">$<%= menuItems[i].price %></h2>
                    <p class="menu-text card-text"><%= menuItems[i].description %></p>
                  </div>
                  <img src="/images/<%= menuItems[i].image %>" alt="<%= menuItems[i].name %>" class="card-img-right">
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <div class="col-lg-3 d-none d-lg-block">
        <div class="loyalty-card">
          <div class="points-label">Your balance</div>
          <div class="points-value"><%= user.points %></div>
          <div class="points-label mb-3">points</div>
          <hr>
          <div class="loyalty-perk"><i class="bi bi-truck"></i> Free delivery over 50 pts</div>
          <div class="loyalty-perk"><i class="bi bi-gift"></i> Redeem points for rewards</div>
          <div class="loyalty-perk"><i class="bi bi-lightning-charge-fill"></i> Earn more on every order</div>
        </div>
      </div>
    </div>
  </div>
  <script src="/favourites.js"></script>
</body>
</html>
