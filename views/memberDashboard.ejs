<%# Done by: Khaing Khant Zaw (Leon) - Member dashboard: search, Order Now mode, ratings, categories, floating cart popup %>
<!DOCTYPE html>
<html>
<head>
    <title>Dashboard | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5 pb-5">

    <!-- search dishes across the whole menu -->
    <form method="GET" action="/dashboard" class="input-group input-group-lg mb-4 shadow-sm">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
      <input type="text" class="form-control border-start-0" name="search"
             placeholder="Search for dishes..." value="<%= search %>">
      <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <% const hour = new Date().getHours();
       const greeting = hour < 12 ? 'Good morning' : (hour < 18 ? 'Good afternoon' : 'Good evening'); %>
    <h2 class="mb-1"><%= greeting %>, <%= user.name %>! 👋</h2>
    <p class="text-muted">What are you craving today?</p>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><%= errors[0] %></div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-8">

        <!-- quick actions: Order Now lights up and reveals the ordering controls -->
        <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
          <div class="col">
            <div class="card h-100 text-center shadow-sm order-now-card" id="orderNowBtn" style="cursor: pointer;">
              <div class="card-body">
                <i class="bi bi-bag-plus fs-2 text-success"></i>
                <h6 class="card-title mt-2 mb-0">Order Now</h6>
                <small class="text-muted" id="orderNowHint">Tap to start ordering</small>
              </div>
            </div>
          </div>
          <div class="col">
            <a href="/book-table" class="text-decoration-none">
              <div class="card h-100 text-center shadow-sm">
                <div class="card-body">
                  <i class="bi bi-calendar-plus fs-2 text-primary"></i>
                  <h6 class="card-title mt-2 mb-0">Book a Table</h6>
                  <small class="text-muted">Reserve your table easily</small>
                </div>
              </div>
            </a>
          </div>
          <div class="col">
            <a href="/favourites" class="text-decoration-none">
              <div class="card h-100 text-center shadow-sm">
                <div class="card-body">
                  <i class="bi bi-heart-fill fs-2 text-danger"></i>
                  <h6 class="card-title mt-2 mb-0">Favourites</h6>
                  <small class="text-muted">Your saved dishes</small>
                </div>
              </div>
            </a>
          </div>
          <div class="col">
            <a href="/complain" class="text-decoration-none">
              <div class="card h-100 text-center shadow-sm">
                <div class="card-body">
                  <i class="bi bi-chat-dots fs-2 text-warning"></i>
                  <h6 class="card-title mt-2 mb-0">Complain</h6>
                  <small class="text-muted">Any complain or suggestion?</small>
                </div>
              </div>
            </a>
          </div>
        </div>

        <!-- category icons + redeem shortcut -->
        <% const icons = { 'Asian': 'bi-egg-fried', 'Tandoori': 'bi-fire', 'Pasta': 'bi-egg',
                           'Pizza': 'bi-circle-half', 'Drinks': 'bi-cup-straw', 'Dessert': 'bi-cake2' }; %>
        <h5 class="mb-3">Categories</h5>
        <div class="d-flex flex-wrap gap-2 mb-4">
          <% for (let i = 0; i < categories.length; i++) { %>
            <a href="/dashboard?category=<%= encodeURIComponent(categories[i].name) %>"
               class="btn <%= !search && activeCategory === categories[i].name ? 'btn-primary' : 'btn-outline-secondary' %>">
              <i class="bi <%= icons[categories[i].name] || 'bi-egg-fried' %>"></i> <%= categories[i].name %>
            </a>
          <% } %>
          <a href="/redeem" class="btn btn-warning"><i class="bi bi-trophy"></i> Redeem</a>
        </div>

        <!-- dishes: search results or the active category (first category by default) -->
        <h5 class="mb-3"><%= search ? `Results for "${search}"` : activeCategory %></h5>
        <% if (dishes.length === 0) { %>
          <div class="alert alert-info">No dishes found<%= search ? ' for this search' : ' in this category' %>.</div>
        <% } %>
        <%# Pasta shows as just two menus (Bolognese / Carbonara) - the pasta
            type gets chosen on the customise page %>
        <% let shownDishes = dishes;
           if (!search && activeCategory === 'Pasta') {
             shownDishes = dishes.filter(d => d.name.indexOf('Spaghetti') === 0);
           } %>
        <div class="row row-cols-1 row-cols-md-2 g-3">
          <% for (let i = 0; i < shownDishes.length; i++) { %>
            <% const displayName = (!search && activeCategory === 'Pasta')
                 ? shownDishes[i].name.replace('Spaghetti ', '') : shownDishes[i].name; %>
            <div class="col">
              <div class="card h-100 shadow-sm food-card">
                <img src="/images/<%= shownDishes[i].image %>" class="card-img-top dish-photo"
                     alt="<%= displayName %>" onerror="this.style.display='none'">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start">
                    <%# clicking the dish opens its detail page - or the
                        customise page when Order Now is switched on %>
                    <h6 class="card-title mb-1">
                      <a href="/dish/<%= shownDishes[i].menu_item_id %>" class="dish-link text-decoration-none text-dark"
                         data-id="<%= shownDishes[i].menu_item_id %>"><%= displayName %></a>
                    </h6>
                    <div class="d-flex align-items-center gap-2">
                      <%# average rating shown beside the heart %>
                      <% if (shownDishes[i].avg_stars) { %>
                        <small class="text-warning fw-bold">
                          <i class="bi bi-star-fill"></i> <%= shownDishes[i].avg_stars %>
                          <span class="text-muted fw-normal">(<%= shownDishes[i].rating_count %>)</span>
                        </small>
                      <% } %>
                      <a href="/favourites/toggle/<%= shownDishes[i].menu_item_id %>?category=<%= encodeURIComponent(activeCategory) %>"
                         class="fav-toggle text-decoration-none fs-5" title="Add or remove favourite">
                        <i class="bi <%= shownDishes[i].is_fav ? 'bi-heart-fill text-danger' : 'bi-heart text-secondary' %>"></i>
                      </a>
                    </div>
                  </div>
                  <p class="card-text text-muted small mb-2"><%= shownDishes[i].description %></p>
                  <div class="d-flex justify-content-between align-items-center">
                    <% if (shownDishes[i].category === 'Pizza' || activeCategory === 'Pizza') { %>
                      <strong>from $15.00</strong>
                    <% } else if (shownDishes[i].category === 'Drinks' || activeCategory === 'Drinks') { %>
                      <strong>from $3.00</strong>
                    <% } else { %>
                      <strong>$<%= shownDishes[i].price %></strong>
                    <% } %>
                    <div class="d-flex align-items-center gap-2">
                      <% if (shownDishes[i].points_cost) { %>
                        <span class="badge bg-warning text-dark"><i class="bi bi-trophy"></i> <%= shownDishes[i].points_cost %> pts</span>
                      <% } %>
                      <%# visible only while Order Now is active %>
                      <a href="/customise/<%= shownDishes[i].menu_item_id %>" class="btn btn-sm btn-success order-add-btn" style="display: none;">
                        <i class="bi bi-cart-plus"></i> Add
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- right column: points card + upcoming booking -->
      <div class="col-lg-4">
        <div class="card shadow-sm mb-3" style="background-color: #fff8e1;">
          <div class="card-body d-flex justify-content-between align-items-center">
            <div>
              <h6 class="mb-1"><i class="bi bi-trophy text-warning"></i> Loyalty Points</h6>
              <p class="mb-0">You have <strong class="fs-4"><%= user.points %></strong> points</p>
            </div>
            <a href="/redeem" class="btn btn-warning">Redeem</a>
          </div>
        </div>

        <%# Order Status: ONLY the member's current order, big, with the
            progress tracker (modelled on the delivery-app reference) %>
        <% if (activeOrder) { %>
          <% const online = activeOrder.order_type === 'online'; %>
          <div class="card shadow-sm mb-3 order-status-big">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Order Status</h5>
                <span class="badge bg-danger-subtle text-danger border border-danger">Order #<%= activeOrder.order_id %></span>
              </div>

              <div class="d-flex gap-3 align-items-center mb-3">
                <% if (activeOrderItems.length > 0) { %>
                  <img src="/images/<%= activeOrderItems[0].image %>" class="rounded order-thumb"
                       alt="" onerror="this.style.display='none'">
                <% } %>
                <div class="flex-grow-1">
                  <strong><%= activeOrderItems.map(it => it.name).join(', ').slice(0, 60) %></strong><br>
                  <small class="text-muted">
                    <i class="bi <%= online ? 'bi-phone' : 'bi-shop' %>"></i>
                    <%= online ? 'Online delivery' : (activeOrder.table_number ? 'Dine-in · Table ' + activeOrder.table_number : 'Dine-in') %>
                  </small>
                </div>
                <div class="text-end">
                  <% if (online && estimate) { %>
                    <small class="text-muted">Estimated</small><br>
                    <strong class="text-danger fs-5"><%= estimate %></strong>
                  <% } else if (!online && activeOrder.table_number) { %>
                    <strong class="text-danger fs-4">T<%= activeOrder.table_number %></strong>
                  <% } %>
                </div>
              </div>

              <%# simple status line instead of a step tracker - we don't
                  track the kitchen in real time %>
              <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge fs-6 <%= activeOrder.status === 'ready' ? 'bg-primary' : 'bg-warning text-dark' %>">
                  <%= activeOrder.status === 'ready' ? 'Ready' : 'Preparing' %>
                </span>
                <small class="text-muted">
                  Ordered at <%= activeOrder.created_at.toLocaleTimeString('en-SG', { hour: 'numeric', minute: '2-digit' }) %>
                </small>
              </div>

              <div class="alert alert-warning py-2 px-3 small mb-3">
                <i class="bi bi-bell"></i>
                <%= activeOrder.status === 'preparing'
                      ? 'The restaurant is preparing your order with care.'
                      : (online ? 'Your order is on the way - enjoy!' : 'Your food is ready!') %>
              </div>

              <div class="d-flex gap-2">
                <a href="/order-status/<%= activeOrder.order_id %>" class="btn btn-outline-secondary btn-sm flex-fill">
                  <i class="bi bi-receipt"></i> View Details
                </a>
                <%# dine-in can still rush the kitchen %>
                <% if (!online) { %>
                  <% if (!activeOrder.impatient) { %>
                    <form method="POST" action="/order-status/<%= activeOrder.order_id %>/rush" class="flex-fill d-grid">
                      <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-lightning-charge-fill"></i> Rush</button>
                    </form>
                  <% } else { %>
                    <span class="btn btn-outline-danger btn-sm flex-fill disabled"><i class="bi bi-lightning-charge-fill"></i> Rushed</span>
                  <% } %>
                <% } %>
                <%# everyone confirms with Received - the card then disappears
                    and the admin sees the green received badge %>
                <form method="POST" action="/order-status/<%= activeOrder.order_id %>/received" class="flex-fill d-grid">
                  <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check2-circle"></i> Received</button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="card shadow-sm mb-3">
            <div class="card-body">
              <h6 class="mb-1"><i class="bi bi-truck text-danger"></i> Order Status</h6>
              <p class="text-muted small mb-0">No active order right now - tap Order Now to get started!</p>
            </div>
          </div>
        <% } %>

        <% if (nextBooking) { %>
          <div class="card shadow-sm border-success mb-3">
            <div class="card-body">
              <h6 class="text-success mb-1"><i class="bi bi-calendar-check"></i> Reservation Confirmed</h6>
              <p class="mb-1">
                <%= nextBooking.reserve_date.toLocaleDateString('en-SG', { dateStyle: 'full' }) %>
                · <%= nextBooking.reserve_time.substring(0, 5) %>
              </p>
              <p class="mb-2 text-muted">Table <%= nextBooking.table_number %> · <%= nextBooking.pax %> pax</p>
              <a href="/book-table" class="btn btn-sm btn-outline-success">View Details</a>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- floating cart button (like food delivery apps) -->
  <button type="button" class="btn btn-primary floating-cart shadow" data-bs-toggle="modal" data-bs-target="#cartModal">
    <i class="bi bi-cart3 fs-4"></i>
    <span class="badge rounded-pill bg-danger cart-badge"><%= cartCount %></span>
  </button>

  <!-- cart popup: blurred background, dine-in vs online -->
  <div class="modal fade" id="cartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-cart3"></i> Your Cart (<%= cartCount %> item<%= cartCount === 1 ? '' : 's' %>)</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <% if (cartItems.length === 0) { %>
            <p class="text-muted mb-0">Your cart is empty - tap <strong>Order Now</strong> and add some dishes!</p>
          <% } else { %>
            <table class="table table-sm align-middle">
              <tbody>
                <% for (let i = 0; i < cartItems.length; i++) { %>
                  <tr>
                    <td>
                      <%= cartItems[i].name %>
                      <% if (cartItems[i].addonNames && cartItems[i].addonNames.length > 0) { %>
                        <br><small class="text-muted">+ <%= cartItems[i].addonNames.join(', ') %></small>
                      <% } %>
                      <% if (cartItems[i].comment) { %>
                        <br><small class="text-muted fst-italic">"<%= cartItems[i].comment %>"</small>
                      <% } %>
                    </td>
                    <td class="text-muted">x<%= cartItems[i].quantity %></td>
                    <td class="text-end">$<%= (cartItems[i].price * cartItems[i].quantity).toFixed(2) %></td>
                  </tr>
                <% } %>
              </tbody>
              <tfoot>
                <tr><th>Subtotal</th><td></td><th class="text-end">$<%= cartSubtotal.toFixed(2) %></th></tr>
                <% if (discountRate > 0) { %>
                  <tr class="text-success">
                    <td colspan="2"><i class="bi bi-credit-card"></i> <%= tier.toUpperCase() %> card discount (<%= discountRate * 100 %>%)</td>
                    <td class="text-end">-$<%= (cartSubtotal * discountRate).toFixed(2) %></td>
                  </tr>
                <% } %>
              </tfoot>
            </table>

            <form method="POST" action="/checkout">
              <p class="mb-2 fw-bold">Where are you eating?</p>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="order_mode" value="restaurant" id="modeRestaurant">
                <label class="form-check-label" for="modeRestaurant"><i class="bi bi-shop"></i> In the restaurant</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="order_mode" value="online" id="modeOnline" checked>
                <label class="form-check-label" for="modeOnline"><i class="bi bi-phone"></i> Order online (delivery)</label>
              </div>

              <!-- shown only for dine-in -->
              <div id="tableBox" class="mb-3 ps-4" style="display: none;">
                <label class="form-label">Table number</label>
                <input type="number" class="form-control" name="table_number" min="1" style="width: 120px">
              </div>

              <!-- shown only for online orders -->
              <div id="deliveryBox" class="mb-3 ps-4">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="delivery_option" value="saver" id="delSaver">
                  <label class="form-check-label" for="delSaver">Saver (45-50 min) <span class="text-success">-$3.00</span></label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="delivery_option" value="standard" id="delStandard" checked>
                  <label class="form-check-label" for="delStandard">Standard (20-35 min)</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="delivery_option" value="priority" id="delPriority">
                  <label class="form-check-label" for="delPriority">Priority (15-20 min) <span class="text-danger">+$3.00</span></label>
                </div>
              </div>

              <button type="submit" class="btn btn-primary w-100">Place Order</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <script>
    // L13 DOM enhancement - Khaing Khant Zaw (Leon)
    // Order Now toggles "ordering mode": the button lights up and clicking a
    // dish opens the CUSTOMISE page instead of the detail/reviews page.
    const orderNowBtn = document.getElementById('orderNowBtn');
    function setOrderMode(on) {
      orderNowBtn.classList.toggle('order-now-active', on);
      // dish names open the customise page instead of the reviews page
      document.querySelectorAll('.dish-link').forEach(a => {
        a.href = (on ? '/customise/' : '/dish/') + a.dataset.id;
      });
      // green Add buttons appear on every dish so the mode is obvious
      document.querySelectorAll('.order-add-btn').forEach(b => {
        b.style.display = on ? 'inline-block' : 'none';
      });
      document.getElementById('orderNowHint').textContent =
        on ? 'Ordering ON - tap a dish to customise' : 'Tap to start ordering';
    }
    let ordering = <%= orderMode ? 'true' : 'false' %>; // stays on after adding an item
    orderNowBtn.addEventListener('click', () => {
      ordering = !ordering;
      setOrderMode(ordering);
    });
    setOrderMode(ordering);

    // the whole dish card is clickable, not just its title
    // (clicks on the heart / Add button keep their own behaviour)
    document.querySelectorAll('.food-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', (e) => {
        if (e.target.closest('a, button, input, select, form')) return;
        const link = card.querySelector('.dish-link');
        if (link) window.location.href = link.getAttribute('href');
      });
    });

    // dine-in asks for a table number, online asks for a delivery speed
    const modeRestaurant = document.getElementById('modeRestaurant');
    const modeOnline = document.getElementById('modeOnline');
    const tableBox = document.getElementById('tableBox');
    const deliveryBox = document.getElementById('deliveryBox');
    function updateMode() {
      if (modeRestaurant && modeRestaurant.checked) {
        tableBox.style.display = 'block';
        deliveryBox.style.display = 'none';
      } else if (tableBox) {
        tableBox.style.display = 'none';
        deliveryBox.style.display = 'block';
      }
    }
    if (modeRestaurant) modeRestaurant.addEventListener('change', updateMode);
    if (modeOnline) modeOnline.addEventListener('change', updateMode);
  </script>
  <script src="/favourites.js"></script>
</body>
</html>
