<%# Done by: Khaing Khant Zaw (Leon) - Reservations: pending, upcoming, phone bookings %>
<!DOCTYPE html>
<html>
<head>
    <title>Reservations</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-4">
    <%- include("partials/adminNav", { activeAdmin: 'reservations' }) %>

    <h1>Reservations</h1>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><%= errors[0] %></div>
    <% } %>

    <!-- pending requests from members -->
    <h4 class="mt-4"><i class="bi bi-hourglass-split"></i> Pending (<%= pending.length %>)</h4>
    <% if (pending.length === 0) { %>
      <div class="alert alert-info">No pending reservation requests.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr><th>Member</th><th>Date</th><th>Time</th><th>Pax</th><th class="text-end">Decision</th></tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < pending.length; i++) { %>
            <tr>
              <td><%= pending[i].name %> <span class="text-muted">(<%= pending[i].card_id %>)</span></td>
              <td><%= pending[i].reserve_date.toLocaleDateString('en-SG', { dateStyle: 'medium' }) %></td>
              <td><%= pending[i].reserve_time.substring(0, 5) %></td>
              <td><%= pending[i].pax %></td>
              <td class="text-end">
                <form method="POST" action="/admin/reservations/accept/<%= pending[i].reservation_id %>" class="d-inline-flex gap-1">
                  <input type="number" class="form-control form-control-sm" name="table_number" placeholder="Table #" min="1" style="width: 90px" required>
                  <button type="submit" class="btn btn-sm btn-success">Accept</button>
                </form>
                <a href="/admin/reservations/remove/<%= pending[i].reservation_id %>" class="btn btn-sm btn-outline-danger"
                   onclick="return confirm('Reject this reservation?')">Reject</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- accepted bookings with tables assigned -->
    <h4 class="mt-4"><i class="bi bi-calendar-check"></i> Upcoming (<%= upcoming.length %>)</h4>
    <% if (upcoming.length === 0) { %>
      <div class="alert alert-info">No upcoming reservations.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr><th>Member</th><th>Date</th><th>Time</th><th>Pax</th><th>Table</th><th class="text-end"></th></tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < upcoming.length; i++) { %>
            <tr>
              <td><%= upcoming[i].name %> <span class="text-muted">(<%= upcoming[i].card_id %>)</span></td>
              <td><%= upcoming[i].reserve_date.toLocaleDateString('en-SG', { dateStyle: 'medium' }) %></td>
              <td><%= upcoming[i].reserve_time.substring(0, 5) %></td>
              <td><%= upcoming[i].pax %></td>
              <td><span class="badge bg-primary">Table <%= upcoming[i].table_number %></span></td>
              <td class="text-end">
                <a href="/admin/reservations/remove/<%= upcoming[i].reservation_id %>" class="btn btn-sm btn-outline-secondary"
                   onclick="return confirm('Remove this reservation? (finished or cancelled)')">
                  <i class="bi bi-check2"></i> Finished / Cancelled
                </a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- phone bookings the admin keys in directly -->
    <h4 class="mt-4"><i class="bi bi-telephone"></i> Add Phone Booking</h4>
    <form method="POST" action="/admin/reservations/add" class="row g-2 align-items-end mb-5">
      <div class="col-auto">
        <label class="form-label">Member Card ID</label>
        <input type="text" class="form-control" name="card_id" placeholder="e.g. J091200" required>
      </div>
      <div class="col-auto">
        <label class="form-label">Date</label>
        <input type="date" class="form-control" name="reserve_date" required>
      </div>
      <div class="col-auto">
        <label class="form-label">Time</label>
        <input type="time" class="form-control" name="reserve_time" required>
      </div>
      <div class="col-auto">
        <label class="form-label">Pax</label>
        <input type="number" class="form-control" name="pax" min="1" max="20" style="width: 80px" required>
      </div>
      <div class="col-auto">
        <label class="form-label">Table #</label>
        <input type="number" class="form-control" name="table_number" min="1" style="width: 90px" required>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary">Add to Upcoming</button>
      </div>
    </form>
  </div>
</body>
</html>
