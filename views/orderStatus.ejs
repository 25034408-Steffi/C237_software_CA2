<%# Done by: Khaing Khant Zaw (Leon) - Order status tracker: progress steps, summary, Received / Rush actions %>
<!DOCTYPE html>
<html>
<head>
    <title>Order #<%= order.order_id %> Status | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>

    <% const online = order.order_type === 'online'; %>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h4 class="mb-0">Order Status</h4>
              <span class="badge bg-light text-danger border">Order #<%= order.order_id %></span>
            </div>
            <p class="text-muted mb-1">
              <%= online ? 'Online order (delivery)' : (order.table_number ? `Dine-in · Table ${order.table_number}` : 'Dine-in') %> ·
              <%= order.created_at.toLocaleString('en-SG', { dateStyle: 'medium', timeStyle: 'short' }) %>
            </p>
            <% if (online && estimate) { %>
              <p class="mb-3">Estimated arrival: <strong class="text-danger fs-5"><%= estimate %></strong>
                <span class="text-muted">(<%= order.delivery_option %> delivery)</span></p>
            <% } %>

            <%# no live tracking - just the current status, big and clear %>
            <div class="mt-3">
              <% const statusBadges = { preparing: 'bg-warning text-dark', ready: 'bg-primary', received: 'bg-success', finished: 'bg-success' }; %>
              <span class="badge fs-5 <%= statusBadges[order.status] %>"><%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %></span>
            </div>

            <% if (order.status === 'preparing') { %>
              <div class="alert alert-warning mt-4 mb-0"><i class="bi bi-bell"></i> The restaurant is preparing your order with care.</div>
            <% } else if (order.status === 'ready') { %>
              <div class="alert alert-primary mt-4 mb-0"><i class="bi bi-bell"></i> <%= online ? 'Your food is on the way!' : 'Your food is ready and coming to your table!' %></div>
            <% } else { %>
              <div class="alert alert-success mt-4 mb-0"><i class="bi bi-check-circle"></i> This order is complete. Enjoy!</div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <% if (order.status === 'preparing' || order.status === 'ready') { %>
          <!-- both dine-in and online: the member confirms once the food arrives -->
          <div class="card shadow-sm mb-3 border-success">
            <div class="card-body text-center">
              <h6><i class="bi bi-house-check text-success"></i> Got your food?</h6>
              <p class="text-muted small">Confirm once your <%= online ? 'order arrives' : 'food reaches the table' %> - the restaurant sees it too.</p>
              <form method="POST" action="/order-status/<%= order.order_id %>/received">
                <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-lg"></i> Received</button>
              </form>
            </div>
          </div>
        <% } %>

        <% if (!online && (order.status === 'preparing' || order.status === 'ready')) { %>
          <!-- dine-in members can ask the kitchen to hurry -->
          <div class="card shadow-sm mb-3" style="background-color: #fff4ec;">
            <div class="card-body text-center">
              <h6><i class="bi bi-lightning-charge-fill text-danger"></i> Need it faster?</h6>
              <p class="text-muted small">Request faster preparation and get your order sooner.</p>
              <% if (order.impatient) { %>
                <div class="alert alert-danger py-2 mb-0"><i class="bi bi-lightning-charge"></i> Rush requested - the kitchen has been notified!</div>
              <% } else { %>
                <form method="POST" action="/order-status/<%= order.order_id %>/rush">
                  <button type="submit" class="btn btn-danger w-100"><i class="bi bi-lightning-charge"></i> Rush My Order</button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>

        <!-- order summary -->
        <div class="card shadow-sm">
          <div class="card-body">
            <h6>Order Summary</h6>
            <table class="table table-sm mb-0">
              <tbody>
                <% let subtotal = 0; %>
                <% for (let i = 0; i < items.length; i++) { %>
                  <% subtotal += Number(items[i].line_total); %>
                  <tr>
                    <td>
                      <%= items[i].name %> <span class="text-muted">x<%= items[i].quantity %></span>
                      <% if (items[i].comment) { %><br><small class="text-muted fst-italic">"<%= items[i].comment %>"</small><% } %>
                    </td>
                    <td class="text-end">$<%= Number(items[i].line_total).toFixed(2) %></td>
                  </tr>
                <% } %>
              </tbody>
              <tfoot>
                <tr><td>Subtotal</td><td class="text-end">$<%= subtotal.toFixed(2) %></td></tr>
                <% if (order.discount_amount > 0) { %>
                  <tr class="text-success"><td>Card discount</td><td class="text-end">-$<%= Number(order.discount_amount).toFixed(2) %></td></tr>
                <% } %>
                <% if (order.delivery_option === 'saver') { %>
                  <tr class="text-success"><td>Saver delivery</td><td class="text-end">-$3.00</td></tr>
                <% } else if (order.delivery_option === 'priority') { %>
                  <tr><td>Priority delivery</td><td class="text-end">+$3.00</td></tr>
                <% } %>
                <tr class="fw-bold"><td>Total paid</td><td class="text-end text-danger">$<%= order.total %></td></tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
