<%# Done by: Khaing Khant Zaw (Leon) - Landing page: brand hero + Register/Log In tab card (TastyBites-style) %>
<!DOCTYPE html>
<html>
<head>
    <title>Supper Club | Great Food, Delivered</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="landing-body">
  <%- include("partials/navbar") %>

  <div class="container-lg py-5">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %>
      </div>
    <% } %>

    <div class="row g-5 align-items-center">

      <!-- left: brand hero with food photos -->
      <div class="col-lg-7">
        <h1 class="landing-title">Fresh flavors,<br><span class="text-brand-orange">happy moments.</span></h1>
        <p class="lead text-muted mb-4">
          Order your favourite meals in minutes with <strong class="text-brand-orange">Supper Club</strong>.
        </p>

        <!-- food photo cluster (from our own menu) -->
        <div class="d-flex align-items-end gap-3 mb-4 flex-wrap">
          <img src="/images/hawaiian_pizza.jpg" alt="Pizza" class="landing-food landing-food-lg">
          <img src="/images/laksa.jpg" alt="Laksa" class="landing-food landing-food-md">
          <img src="/images/butter_chicken.jpg" alt="Butter Chicken" class="landing-food landing-food-md">
          <img src="/images/tiramisu.jpg" alt="Tiramisu" class="landing-food landing-food-sm">
        </div>

        <div class="row g-3">
          <div class="col-md-4">
            <div class="landing-chip">
              <i class="bi bi-scooter text-brand-orange fs-3"></i>
              <div>
                <strong>Fast Delivery</strong>
                <small class="d-block text-muted">Quick and reliable delivery to your doorstep.</small>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="landing-chip">
              <i class="bi bi-geo-alt-fill text-brand-orange fs-3"></i>
              <div>
                <strong>Easy Tracking</strong>
                <small class="d-block text-muted">Track your order in real-time every step of the way.</small>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="landing-chip">
              <i class="bi bi-egg-fried text-brand-orange fs-3"></i>
              <div>
                <strong>Fresh Meals</strong>
                <small class="d-block text-muted">Made with quality ingredients and cooked to perfection.</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- right: welcome card with Register / Log In tabs -->
      <div class="col-lg-5">
        <div class="card landing-card shadow">
          <div class="card-body p-4">
            <% if (user) { %>
              <h3 class="text-center mb-1">Welcome back, <%= user.name %>!</h3>
              <p class="text-center text-muted">Ready for something delicious?</p>
              <div class="d-grid gap-2">
                <a href="<%= user.role === 'admin' ? '/admin' : '/dashboard' %>" class="btn btn-brand-orange btn-lg">
                  Go to Dashboard <i class="bi bi-arrow-right"></i>
                </a>
                <a href="/logout" class="btn btn-outline-secondary">Logout</a>
              </div>
            <% } else { %>
              <%# the card swaps between three panes IN PLACE (L13 DOM) -
                  welcome -> register form or login form, with a back arrow.
                  The forms still post to the same old /register and /login routes. %>

              <!-- pane 1: welcome -->
              <div id="welcomePane">
                <h3 class="text-center mb-1">Welcome</h3>
                <p class="text-center text-muted mb-4">Create your account or log in to continue.</p>
                <div class="d-grid gap-2">
                  <button type="button" class="btn btn-brand-orange btn-lg" id="showRegister">
                    <i class="bi bi-person-plus"></i> Create Account <i class="bi bi-arrow-right"></i>
                  </button>
                </div>
                <div class="landing-divider my-3"><span>or</span></div>
                <div class="d-grid">
                  <button type="button" class="btn btn-outline-brand-orange btn-lg" id="showLogin">
                    <i class="bi bi-person"></i> Log In
                  </button>
                </div>
              </div>

              <!-- pane 2: register form (hidden until picked) -->
              <div id="registerPane" style="display: none;">
                <div class="d-flex align-items-center mb-3">
                  <button type="button" class="btn btn-sm btn-outline-secondary back-btn me-2" title="Back">
                    <i class="bi bi-arrow-left"></i>
                  </button>
                  <h4 class="mb-0">Create Account</h4>
                </div>
                <form method="POST" action="/register">
                  <div class="input-group mb-3">
                    <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                    <input type="text" class="form-control" name="name" placeholder="Full Name" required>
                  </div>
                  <div class="input-group mb-3">
                    <span class="input-group-text bg-white"><i class="bi bi-telephone"></i></span>
                    <input type="text" class="form-control" name="telephoneNo" placeholder="Phone Number" required>
                  </div>
                  <div class="input-group mb-3">
                    <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                    <input type="password" class="form-control" name="password" placeholder="Password" minlength="6" required>
                  </div>
                  <div class="input-group mb-4">
                    <span class="input-group-text bg-white"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" class="form-control" name="confirmPassword" placeholder="Confirm Password" minlength="6" required>
                  </div>
                  <div class="d-grid">
                    <button type="submit" class="btn btn-brand-orange btn-lg">Create Account <i class="bi bi-arrow-right"></i></button>
                  </div>
                </form>
              </div>

              <!-- pane 3: login form (hidden until picked) -->
              <div id="loginPane" style="display: none;">
                <div class="d-flex align-items-center mb-3">
                  <button type="button" class="btn btn-sm btn-outline-secondary back-btn me-2" title="Back">
                    <i class="bi bi-arrow-left"></i>
                  </button>
                  <h4 class="mb-0">Log In</h4>
                </div>
                <form method="POST" action="/login">
                  <div class="input-group mb-3">
                    <span class="input-group-text bg-white"><i class="bi bi-credit-card"></i></span>
                    <input type="text" class="form-control" name="card_id" placeholder="Membership Card ID" required>
                  </div>
                  <div class="input-group mb-4">
                    <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                    <input type="password" class="form-control" name="password" placeholder="Password" required>
                  </div>
                  <div class="d-grid">
                    <button type="submit" class="btn btn-brand-orange btn-lg">Log In <i class="bi bi-arrow-right"></i></button>
                  </div>
                </form>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (!user) { %>
  <script>
    // L13 DOM enhancement - the card changes in place, no page navigation
    const panes = ['welcomePane', 'registerPane', 'loginPane'];
    function showPane(id) {
      panes.forEach(p => document.getElementById(p).style.display = (p === id ? 'block' : 'none'));
    }
    document.getElementById('showRegister').addEventListener('click', () => showPane('registerPane'));
    document.getElementById('showLogin').addEventListener('click', () => showPane('loginPane'));
    // every back arrow returns to the welcome pane
    document.querySelectorAll('.back-btn').forEach(b => b.addEventListener('click', () => showPane('welcomePane')));
  </script>
  <% } %>
</body>
</html>
