<!DOCTYPE html>
<html>
<head>
    <title>Supper Club | Great Food, Delivered</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>

  <section class="hero">
    <h1>Great food, delivered with heart</h1>
    <p class="lead">Order your favourites, earn points on every purchase, and enjoy a menu made to satisfy.</p>

    <% if (user) { %>
      <a href="/menu" class="btn btn-amber btn-lg">Browse the menu</a>
    <% } else { %>
      <a href="/register" class="btn btn-amber btn-lg">Get Started</a>
      <a href="/login" class="btn btn-outline-light btn-brand btn-lg">Login</a>
    <% } %>
  </section>

  <div class="container feature-strip">
    <% if (messages && messages.length > 0) { %>
      <div class="welcome-banner">
        <% messages.forEach(function(message) { %>
          <p class="mb-1"><%= message %></p>
        <% }); %>
        <% if (user) { %>
          <h2 class="mt-2">Welcome, <%= user.name %>!</h2>
          <a href="/menu" class="btn btn-primary mt-3">Order now</a>
          <a href="/logout" class="btn btn-outline-secondary mt-3">Logout</a>
        <% } %>
      </div>
    <% } %>

    <div class="row g-4 mt-1 mb-5">
      <div class="col-md-4">
        <div class="feature-card">
          <i class="bi bi-lightning-charge-fill"></i>
          <h3>Fast Delivery</h3>
          <p>Hot food, delivered quickly to your door.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <i class="bi bi-egg-fried"></i>
          <h3>Fresh Ingredients</h3>
          <p>Quality dishes made with care, every time.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <i class="bi bi-star-fill"></i>
          <h3>Earn Rewards</h3>
          <p>Collect points with every order and redeem perks.</p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
