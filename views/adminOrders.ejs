<%# Done by: Khaing Khant Zaw (Leon) - Orders: online & in-restaurant tabs, status updates, impatient flag %>
<!DOCTYPE html>
<html>
<head>
    <title>Orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-4">
    <%- include("partials/adminNav", { activeAdmin: 'orders' }) %>

    <h1>Orders</h1>

    <ul class="nav nav-tabs mb-3">
      <li class="nav-item">
        <a class="nav-link <%= activeTab === 'online' ? 'active' : '' %>" href="/admin/orders/online">
          <i class="bi bi-phone"></i> Online
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= activeTab === 'restaurant' ? 'active' : '' %>" href="/admin/orders/restaurant">
          <i class="bi bi-shop"></i> In Restaurant
        </a>
      </li>
    </ul>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>

    <% if (orders.length === 0) { %>
      <div class="alert alert-info">No <%= activeTab === 'online' ? 'online' : 'in-restaurant' %> orders yet.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>Member</th>
            <th>Placed</th>
            <th>Total</th>
            <th>Status</th>
            <th class="text-end">Set Status</th>
          </tr>
        </thead>
        <tbody>
          <% const badges = { preparing: 'bg-warning text-dark', ready: 'bg-primary', received: 'bg-info text-dark', finished: 'bg-success' }; %>
          <% for (let i = 0; i < orders.length; i++) { %>
            <tr>
              <td><%= orders[i].order_id %></td>
              <td>
                <%= orders[i].name %> <span class="text-muted">(<%= orders[i].card_id %>)</span>
                <% if (orders[i].impatient) { %>
                  <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> impatient</span>
                <% } %>
              </td>
              <td><%= orders[i].created_at.toLocaleString('en-SG', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
              <td>$<%= orders[i].total %></td>
              <td><span class="badge <%= badges[orders[i].status] %>"><%= orders[i].status %></span></td>
              <td class="text-end">
                <% if (orders[i].status === 'preparing' || orders[i].status === 'ready') { %>
                  <% if (orders[i].status === 'preparing' && activeTab === 'restaurant') { %>
                    <a href="/admin/orders/<%= activeTab %>/status/<%= orders[i].order_id %>/ready" class="btn btn-sm btn-outline-primary">Ready</a>
                  <% } %>
                  <%# staff confirms the hand-over if the member has not %>
                  <a href="/admin/orders/<%= activeTab %>/status/<%= orders[i].order_id %>/received" class="btn btn-sm btn-outline-success">Received</a>
                  <% if (activeTab === 'restaurant') { %>
                    <a href="/admin/orders/<%= activeTab %>/status/<%= orders[i].order_id %>/finished" class="btn btn-sm btn-outline-secondary">Finish</a>
                  <% } %>
                <% } else if (orders[i].status === 'received') { %>
                  <a href="/admin/orders/<%= activeTab %>/status/<%= orders[i].order_id %>/finished" class="btn btn-sm btn-outline-secondary">Finish</a>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
    <p class="text-muted">
      Members confirm with <em>Received</em> from their side - the badge turns green here when they do.
      If they forget, use <em>Received</em> (or <em>Finish</em>) to close the order yourself.
    </p>
  </div>
</body>
</html>
