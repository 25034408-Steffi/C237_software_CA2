<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="register-page-body">
  <%- include("partials/navbar") %>
    <div class="container">
      <div class="container-lg mt-5">

        <div class="row justify-content-center">
          <div class="col-lg-4 register">
              <h1>Register</h1>
            <% if (messages && messages.length > 0) { %>
              <div class="alert alert-danger py-2 px-3">
                  <% messages.forEach(function(message) { %>
                      <p><%= message %></p>
                  <% }); %>
              </div>
            <% } %>

            <form action="/register" method="POST" class="mt-4">
              <div class="mb-3">
                <label for="name" class="form-label">Name:</label>
                <input type="text" id="name" name="name" placeholder="Full name" class="form-control" required
                  <% if (formData && formData.name) { %> value="<%= formData.email %>" <% } else { %> value="" <% } %>>
              </div>
              <div class="mb-3">
                <label for="telephoneNo" class="form-label">Phone:</label>
                <input type="tel" id="telephoneNo" name="telephoneNo" placeholder="12345678" 
                inputmode="numeric" pattern="[0-9]{8}" class="form-control" title="Phone number must be exactly 8 digits" required
                  <% if (formData && formData.telephoneNo) { %> value="<%= formData.telephoneNo %>" <% } else { %> value="" <% } %>>
              </div>
              <div class="mb-3">
                <label for="password" class="form-label">Password:</label>
                <input type="password" id="password" name="password" maxlength="20"
                placeholder="Create a password" class="form-control" required>
              </div>
  
              <button type="submit" class="btn btn-primary w-100">Login</button>
              <div class="mt-3 text-center">
                <span class="register-text">
                  Already have an account? <a href="/login">Register</a>
                </span>
              </div>
              
            </form>
          </div>
        </div>
      </div>
    </div>
</body>
</html>
