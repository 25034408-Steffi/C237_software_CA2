<!DOCTYPE html>
<html>
<head>
    <title>Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="profile-page-body">
  <%- include("partials/navbar") %>
  <div class="container">
    <div class="container-lg mt-5">
      <!-- Back to menu link -->
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <%# back goes to the right home for the role - Khaing Khant Zaw (Leon) %>
          <% if (user && user.role === 'admin') { %>
            <a href="/admin" class="btn btn-link ps-0 mb-2 text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
          <% } else { %>
            <a href="/dashboard" class="btn btn-link ps-0 mb-2 text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
          <% } %>
        </div>
      </div>

      <!-- Profile card: avatar + read-only info + Edit Profile button -->
      <div class="row justify-content-center">
        <div class="col-lg-8 profile">
          <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger py-2 px-3 my-1"><% errors.forEach(function(error) { %><p class="mb-0"><%= error %></p><% }); %></div>
          <% } %>
          <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success py-2 px-3 my-1"><% messages.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %></div>
          <% } %>
          <div class="row align-items-center">
            <div class="col-12 col-md-4 text-center mb-4 mb-md-0">
              <i class="bi bi-person-circle profile-avatar"></i>
              <h5 class="mt-3 mb-0"><%= profileUser.name %></h5>
              <span class="text-capitalize text-muted"><%= profileUser.role %></span>
            </div>
            <div class="col-12 col-md-8">
              <div class="profile-info">
                <div class="profile-info-row">
                  <span class="profile-label">Card ID:</span>
                  <span class="profile-value"><%= profileUser.card_id %></span>
                </div>
                <div class="profile-info-row">
                  <span class="profile-label">Name:</span>
                  <span class="profile-value"><%= profileUser.name %></span>
                </div>
                <div class="profile-info-row">
                  <span class="profile-label">Phone Number:</span>
                  <span class="profile-value"><%= profileUser.phone_number %></span>
                </div>
                <div class="profile-info-row">
                  <span class="profile-label">Points:</span>
                  <span class="profile-value"><%= profileUser.points %></span>
                </div>
              </div>
              <div class="text-end mt-3">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                  <i class="bi bi-pencil-square me-1"></i>Edit Profile
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <%# ============================================================
          Done by: Khaing Khant Zaw (Leon)
          Membership card: shows the member's current card and lets them
          switch between Basic / Silver / Gold / VIP (discount changes too)
          ============================================================ %>
      <% if (profileUser.role === 'customer') { %>
      <% const tierInfo = {
           basic:  { label: 'Basic Card',  icon: 'bi-credit-card',      discount: 'No discount' },
           silver: { label: 'Silver Card', icon: 'bi-credit-card-2-front', discount: '5% off every order' },
           gold:   { label: 'Gold Card',   icon: 'bi-credit-card-fill', discount: '10% off every order' },
           vip:    { label: 'VIP Card',    icon: 'bi-gem',              discount: '15% off every order' }
         };
         const myTier = profileUser.card_tier || 'basic'; %>
      <div class="row justify-content-center mt-4">
        <div class="col-lg-8 profile">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">My Membership Card</h5>
            <button type="button" class="btn btn-outline-primary btn-sm" id="switchCardBtn">
              <i class="bi bi-arrow-left-right me-1"></i>Switch Card
            </button>
          </div>

          <!-- the member's current card -->
          <div class="member-card card-<%= myTier %>">
            <div class="d-flex justify-content-between align-items-start">
              <i class="bi <%= tierInfo[myTier].icon %> fs-1"></i>
              <span class="member-card-tier"><%= tierInfo[myTier].label %></span>
            </div>
            <div class="mt-4">
              <div class="member-card-number"><%= profileUser.card_id %></div>
              <div class="d-flex justify-content-between align-items-end">
                <span><%= profileUser.name %></span>
                <small><%= tierInfo[myTier].discount %></small>
              </div>
            </div>
          </div>

          <!-- switch panel: hidden until Switch Card is tapped (L13 DOM) -->
          <div id="cardChoices" class="row row-cols-2 row-cols-md-4 g-2 mt-2" style="display: none;">
            <% ['basic', 'silver', 'gold', 'vip'].forEach(function(t) { %>
              <div class="col">
                <form method="POST" action="/profile/card">
                  <input type="hidden" name="card_tier" value="<%= t %>">
                  <button type="submit" class="member-card-mini card-<%= t %> w-100 <%= t === myTier ? 'member-card-current' : '' %>">
                    <i class="bi <%= tierInfo[t].icon %> fs-3"></i>
                    <div class="fw-bold"><%= tierInfo[t].label %></div>
                    <small><%= tierInfo[t].discount %></small>
                    <% if (t === myTier) { %><div><small><i class="bi bi-check-circle-fill"></i> current</small></div><% } %>
                  </button>
                </form>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
      <script>
        // tap Switch Card to reveal / hide the four card designs
        document.getElementById('switchCardBtn').addEventListener('click', () => {
          const panel = document.getElementById('cardChoices');
          panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
        });
      </script>
      <% } %>

      <!--
        Family Members card.
        isFamilyOwner = true when profileUser.primary_user_id IS NULL (they're the account owner).
        Owners get the "Add Family Member" button + a delete button per row.
        Non-owners see the same list read-only.
      -->
      <div class="row justify-content-center mt-4">
        <div class="col-lg-8 profile">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Family Members</h5>
            <% if (isFamilyOwner) { %>
              <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addFamilyMemberModal">
                <i class="bi bi-person-plus me-1"></i>Add Family Member
              </button>
            <% } %>
          </div>

          <div class="profile-info">
            <% familyMembers.forEach(function(member) { %>
              <div class="profile-info-row justify-content-between">
                <div>
                  <span class="profile-value"><%= member.name %></span>
                  <span class="text-muted text-capitalize ms-2">(<%= member.relationship_name %>)</span>
                  <div class="profile-label">Card ID: <%= member.card_id %>  Points: <%= member.points %></div>
                </div>
                <% if (isFamilyOwner && !member.is_owner) { %>
                  <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#editMemberModal<%= member.user_id %>">
                      <i class="bi bi-pencil-square me-1"></i>Edit
                    </button>
                    <form action="/profile/family/<%= member.user_id %>/delete" method="POST" onsubmit="return confirm('Remove <%= member.name %> from your family?');">
                      <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash me-1"></i>Remove
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Family Member modals (owner only, one per member, posts to /profile/family/:id/edit) -->
  <% if (isFamilyOwner) { %>
    <% familyMembers.forEach(function(member) { %>
      <% if (!member.is_owner) { %>
        <div class="modal fade" id="editMemberModal<%= member.user_id %>" tabindex="-1" aria-labelledby="editMemberModalLabel<%= member.user_id %>" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <form action="/profile/family/<%= member.user_id %>/edit" method="POST">
                <div class="modal-header">
                  <h5 class="modal-title" id="editMemberModalLabel<%= member.user_id %>">Edit <%= member.name %></h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <div class="mb-3">
                    <label class="form-label" for="member_name<%= member.user_id %>">Name</label>
                    <input class="form-control" type="text" id="member_name<%= member.user_id %>" name="name" value="<%= member.name %>" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label" for="member_relationship<%= member.user_id %>">Relationship</label>
                    <select class="form-select" id="member_relationship<%= member.user_id %>" name="relationship_type_id" required>
                      <% relationshipTypes.forEach(function(type) { %>
                        <option value="<%= type.relationship_type_id %>" class="text-capitalize" <%= type.relationship_type_id === member.relationship_type_id ? 'selected' : '' %>><%= type.name %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="mb-3">
                    <label class="form-label" for="member_password<%= member.user_id %>">New Password</label>
                    <input class="form-control" type="password" id="member_password<%= member.user_id %>" name="password" placeholder="Leave blank to keep current password">
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    <% }); %>
  <% } %>

  <!-- Add Family Member modal (owner only, posts to /profile/family/add) -->
  <% if (isFamilyOwner) { %>
    <div class="modal fade" id="addFamilyMemberModal" tabindex="-1" aria-labelledby="addFamilyMemberModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <form action="/profile/family/add" method="POST">
            <div class="modal-header">
              <h5 class="modal-title" id="addFamilyMemberModalLabel">Add Family Member</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label" for="family_name">Name</label>
                <input class="form-control" type="text" id="family_name" name="name" required>
              </div>
              <div class="mb-3">
                <label class="form-label" for="family_phone_number">Phone Number</label>
                <input class="form-control" type="text" id="family_phone_number" name="phone_number" required>
              </div>
              <div class="mb-3">
                <label class="form-label" for="family_password">Password</label>
                <input class="form-control" type="password" id="family_password" name="password" required>
              </div>
              <div class="mb-3">
                <label class="form-label" for="relationship_type_id">Relationship</label>
                <select class="form-select" id="relationship_type_id" name="relationship_type_id" required>
                  <option value="" disabled selected>Select relationship</option>
                  <% relationshipTypes.forEach(function(type) { %>
                    <option value="<%= type.relationship_type_id %>" class="text-capitalize"><%= type.name %></option>
                  <% }); %>
                </select>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary">Add Member</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Edit Profile modal (name + phone number only, posts to /profile) -->
  <div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form action="/profile" method="POST">
          <div class="modal-header">
            <h5 class="modal-title" id="editProfileModalLabel">Edit Profile</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label" for="name">Name</label>
              <input class="form-control" type="text" id="name" name="name" value="<%= profileUser.name %>" required>
            </div>
            <div class="mb-3">
              <label class="form-label" for="phone_number">Phone Number</label>
              <input class="form-control" type="text" id="phone_number" name="phone_number" value="<%= profileUser.phone_number %>" required>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
