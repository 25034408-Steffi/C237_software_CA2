<%# Done by: Khaing Khant Zaw (Leon) - Book a table: request + my reservations %>
<!DOCTYPE html>
<html>
<head>
    <title>Book a Table | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    <h2><i class="bi bi-calendar-plus"></i> Book a Table</h2>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><%= errors[0] %></div>
    <% } %>

    <div class="card shadow-sm mb-4 col-lg-8">
      <div class="card-body">
        <form method="POST" action="/book-table" class="row g-2 align-items-end">
          <div class="col-auto">
            <label class="form-label">Date</label>
            <input type="date" class="form-control" name="reserve_date" required>
          </div>
          <div class="col-auto">
            <label class="form-label">Time</label>
            <input type="time" class="form-control" name="reserve_time" required>
          </div>
          <div class="col-auto">
            <label class="form-label">How many people?</label>
            <input type="number" class="form-control" name="pax" min="1" max="20" required>
          </div>
          <div class="col-auto">
            <button type="submit" class="btn btn-primary">Request Booking</button>
          </div>
        </form>
        <small class="text-muted">The restaurant will confirm your booking and assign you a table.</small>
      </div>
    </div>

    <h5>My Reservations</h5>
    <% if (reservations.length === 0) { %>
      <div class="alert alert-info">You have no reservations yet.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle bg-white">
        <thead>
          <tr><th>Date</th><th>Time</th><th>Pax</th><th>Table</th><th>Status</th><th class="text-end"></th></tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < reservations.length; i++) { %>
            <tr>
              <td><%= reservations[i].reserve_date.toLocaleDateString('en-SG', { dateStyle: 'medium' }) %></td>
              <td><%= reservations[i].reserve_time.substring(0, 5) %></td>
              <td><%= reservations[i].pax %></td>
              <td><%= reservations[i].table_number ? 'Table ' + reservations[i].table_number : '-' %></td>
              <td>
                <% if (reservations[i].status === 'pending') { %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% } else { %>
                  <span class="badge bg-success">Confirmed</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/book-table/cancel/<%= reservations[i].reservation_id %>" class="btn btn-sm btn-outline-danger"
                   onclick="return confirm('Cancel this reservation?')">Cancel</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>
