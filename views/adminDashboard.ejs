<%# Done by: Khaing Khant Zaw (Leon) - Admin dashboard with live database counts %>
<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-3">
    <%- include("partials/adminNav", { activeAdmin: 'dashboard' }) %>
  </div>
  <div class="container mt-4">
    <h1><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
    <p class="text-muted">Welcome back, <%= user.name %> (<%= user.card_id %>)</p>

    <!-- quick stats from the database -->
    <div class="row row-cols-2 row-cols-lg-4 g-3 mb-4">
      <div class="col">
        <div class="card text-center">
          <div class="card-body">
            <h2 class="card-title"><%= counts.totalItems %></h2>
            <p class="card-text text-muted">Menu Items</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card text-center">
          <div class="card-body">
            <h2 class="card-title"><%= counts.eightySixed %></h2>
            <p class="card-text text-muted">86'd (Sold Out)</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card text-center">
          <div class="card-body">
            <h2 class="card-title"><%= counts.totalCategories %></h2>
            <p class="card-text text-muted">Categories</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card text-center">
          <div class="card-body">
            <h2 class="card-title"><%= counts.totalMembers %></h2>
            <p class="card-text text-muted">Members</p>
          </div>
        </div>
      </div>
    </div>

    <!-- admin features: buttons get wired up as each feature is built -->
    <div class="row row-cols-1 row-cols-lg-3 g-3">
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><i class="bi bi-card-list"></i> Manage Menu</h5>
            <p class="card-text">Add, edit or delete menu items and upload food photos.</p>
            <a href="/admin/menu" class="btn btn-primary">Open</a>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><i class="bi bi-slash-circle"></i> 86 List</h5>
            <p class="card-text">Mark items as sold out so members cannot order them.</p>
            <a href="/admin/menu/86" class="btn btn-primary">Open</a>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><i class="bi bi-receipt"></i> Orders</h5>
            <p class="card-text">View incoming orders and update their status.</p>
            <a href="/admin/orders" class="btn btn-primary">Open</a>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><i class="bi bi-people"></i> Members</h5>
            <p class="card-text">View club members and manage their card tiers.</p>
            <a href="/admin/members" class="btn btn-primary">Open</a>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><i class="bi bi-calendar-check"></i> Reservations</h5>
            <p class="card-text">Approve or reject pending table reservations.</p>
            <a href="/admin/reservations" class="btn btn-primary">Open</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
