<!DOCTYPE html>
<html>
<head>
    <title>Complaints</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-4">
    <%- include("partials/adminNav", { activeAdmin: 'complaints' }) %>

    <h1><i class="bi bi-chat-dots"></i> Complaints & Opinions</h1>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>

    <% if (complaints.length === 0) { %>
      <div class="alert alert-info">No feedback from members right now.</div>
    <% } %>

    <% const topicBadges = { food: 'bg-danger', staff: 'bg-primary', service: 'bg-warning text-dark', other: 'bg-secondary' }; %>
    <div class="row row-cols-1 row-cols-lg-2 g-3">
      <% for (let i = 0; i < complaints.length; i++) { %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <strong><%= complaints[i].name %></strong>
                  <span class="text-muted">(<%= complaints[i].card_id %>)</span>
                </div>
                <span class="badge <%= topicBadges[complaints[i].topic] %>"><%= complaints[i].topic %></span>
              </div>
              <p class="card-text"><%= complaints[i].message %></p>
              <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">
                  <%= complaints[i].created_at.toLocaleString('en-SG', { dateStyle: 'medium', timeStyle: 'short' }) %>
                </small>
                <a href="/admin/complaints/remove/<%= complaints[i].complaint_id %>" class="btn btn-sm btn-outline-success"
                   onclick="return confirm('Mark this complaint as handled and clear it?')">
                  <i class="bi bi-check2"></i> Handled
                </a>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
