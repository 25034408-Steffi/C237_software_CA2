<!DOCTYPE html>
<html>
<head>
    <title>Favourites | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    <h2><i class="bi bi-heart-fill text-danger"></i> My Favourites</h2>

    <div id="noFavAlert" class="alert alert-info mt-3 <%= favourites.length === 0 ? '' : 'd-none' %>">
      No favourites yet - tap the <i class="bi bi-heart"></i> on any dish in the dashboard to save it here.
    </div>

    <div id="favouritesGrid" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mt-1">
      <% for (let i = 0; i < favourites.length; i++) { %>
        <div class="col">
          <div class="card h-100 shadow-sm food-card">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <h6 class="card-title mb-1"><%= favourites[i].name %></h6>
                <a href="/favourites/toggle/<%= favourites[i].menu_item_id %>?back=favourites"
                   class="fav-toggle text-decoration-none fs-5" title="Remove favourite" data-remove-on-unfav="true">
                  <i class="bi bi-heart-fill text-danger"></i>
                </a>
              </div>
              <span class="badge bg-secondary mb-2"><%= favourites[i].category %></span>
              <p class="card-text text-muted small mb-2"><%= favourites[i].description %></p>
              <strong>$<%= favourites[i].price %></strong>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
  <script src="/favourites.js"></script>
</body>
</html>
