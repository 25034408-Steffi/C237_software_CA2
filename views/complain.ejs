<%# Done by: Khaing Khant Zaw (Leon) - Member complaint / suggestion form %>
<!DOCTYPE html>
<html>
<head>
    <title>Feedback | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    <h2><i class="bi bi-chat-dots text-warning"></i> Any Complain or Suggestion?</h2>
    <p class="text-muted">Tell us about the food, our staff, or anything else - the manager reads every message.</p>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><%= errors[0] %></div>
    <% } %>

    <div class="card shadow-sm col-lg-7">
      <div class="card-body">
        <form method="POST" action="/complain">
          <div class="mb-3">
            <label class="form-label">What is it about?</label>
            <select class="form-select" name="topic" required>
              <option value="">Choose a topic...</option>
              <option value="food">The food</option>
              <option value="staff">Restaurant staff</option>
              <option value="service">Service / waiting time</option>
              <option value="other">Something else</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Your message</label>
            <textarea class="form-control" name="message" rows="4" maxlength="1000" required
                      placeholder="Tell us what happened or what we could do better..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Feedback</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
