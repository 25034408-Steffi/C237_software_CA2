<!DOCTYPE html>
<html>
<head>
    <title>Order #<%= order.order_id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-4">
    <%- include("partials/adminNav", { activeAdmin: 'members' }) %>

    <a href="/admin/members/<%= member.user_id %>" class="btn btn-sm btn-outline-secondary mb-2">
      <i class="bi bi-arrow-left"></i> Back to <%= member.name %>'s spending
    </a>

    <h1>Order #<%= order.order_id %></h1>
    <p class="text-muted">
      <%= member.name %> (<%= member.card_id %>) ·
      <%= order.created_at.toLocaleString('en-SG', { dateStyle: 'full', timeStyle: 'short' }) %> ·
      <%= order.order_type === 'online' ? 'Online' : 'In restaurant' %> · <%= order.status %>
    </p>

    <div class="table-responsive col-lg-8">
      <table class="table table-hover align-middle">
        <thead>
          <tr><th>Item</th><th>Category</th><th>Unit Price</th><th>Qty</th><th class="text-end">Line Total</th></tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < items.length; i++) { %>
            <tr>
              <td>
                <%= items[i].name %>
                <% if (items[i].comment) { %>
                  <br><small class="text-muted fst-italic">"<%= items[i].comment %>"</small>
                <% } %>
              </td>
              <td><%= items[i].category %></td>
              <td>$<%= items[i].price %></td>
              <td><%= items[i].quantity %></td>
              <td class="text-end">$<%= Number(items[i].line_total).toFixed(2) %></td>
            </tr>
          <% } %>
        </tbody>
        <tfoot>
          <tr>
            <th colspan="4">Order Total (as charged)</th>
            <th class="text-end">$<%= order.total %></th>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</body>
</html>
