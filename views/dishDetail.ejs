<%# Done by: Khaing Khant Zaw (Leon) - Dish detail: description, filled-star ratings and member reviews %>
<!DOCTYPE html>
<html>
<head>
    <title><%= item.name %> | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5 col-lg-8">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>

    <%# five star icons, filled according to the average %>
    <% const fullStars = Math.round(avg); %>
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <span class="badge bg-secondary mb-1"><%= item.category %></span>
            <h2 class="mb-1"><%= item.name %></h2>
            <div class="mb-2">
              <% for (let s = 1; s <= 5; s++) { %>
                <i class="bi <%= s <= fullStars ? 'bi-star-fill' : 'bi-star' %> text-warning"></i>
              <% } %>
              <% if (reviews.length > 0) { %>
                <strong><%= avg %></strong> <span class="text-muted">· <%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %></span>
              <% } else { %>
                <span class="text-muted">No reviews yet - be the first!</span>
              <% } %>
            </div>
          </div>
          <h3 class="text-nowrap">$<%= item.price %></h3>
        </div>
        <p class="text-muted mb-0"><%= item.description %></p>
      </div>
    </div>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success"><%= messages[0] %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger"><%= errors[0] %></div>
    <% } %>

    <!-- what other members said -->
    <h5 class="mb-3"><i class="bi bi-chat-square-text"></i> Member Reviews</h5>
    <% for (let i = 0; i < reviews.length; i++) { %>
      <div class="card shadow-sm mb-2">
        <div class="card-body py-2">
          <div class="d-flex justify-content-between align-items-center">
            <strong><%= reviews[i].name %></strong>
            <span>
              <% for (let s = 1; s <= 5; s++) { %>
                <i class="bi <%= s <= reviews[i].stars ? 'bi-star-fill' : 'bi-star' %> text-warning"></i>
              <% } %>
            </span>
          </div>
          <% if (reviews[i].comment) { %>
            <p class="mb-0 text-muted"><%= reviews[i].comment %></p>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- leave (or update) your own review -->
    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <h6>Your review</h6>
        <form method="POST" action="/rate/<%= item.menu_item_id %>" class="row g-2 align-items-end">
          <div class="col-auto">
            <label class="form-label">Stars</label>
            <select class="form-select" name="stars" style="width: 100px">
              <option value="5">5 ★</option>
              <option value="4">4 ★</option>
              <option value="3">3 ★</option>
              <option value="2">2 ★</option>
              <option value="1">1 ★</option>
            </select>
          </div>
          <div class="col">
            <label class="form-label">Comment (optional)</label>
            <input type="text" class="form-control" name="comment" maxlength="500" placeholder="How was it?">
          </div>
          <div class="col-auto">
            <button type="submit" class="btn btn-warning"><i class="bi bi-star"></i> Submit</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
