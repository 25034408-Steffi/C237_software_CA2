<!DOCTYPE html>
<html>
<head>
    <title>Redeem Points | Supper Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body class="bg-light">
  <%- include("partials/navbar") %>
  <div class="container mt-4 mb-5">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    <h2><i class="bi bi-trophy text-warning"></i> Redeem Your Points</h2>

    <div class="alert alert-warning col-lg-6">
      You have <strong class="fs-5"><%= user.points %></strong> points to spend.
      Redeem these treats when placing your order.
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mt-1">
      <% for (let i = 0; i < items.length; i++) { %>
        <% const canAfford = user.points >= items[i].points_cost; %>
        <div class="col">
          <div class="card h-100 shadow-sm food-card <%= canAfford ? 'border-warning' : '' %>">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <h6 class="card-title mb-1"><%= items[i].name %></h6>
                <span class="badge bg-warning text-dark"><%= items[i].points_cost %> pts</span>
              </div>
              <span class="badge bg-secondary mb-2"><%= items[i].category %></span>
              <p class="card-text text-muted small mb-2"><%= items[i].description %></p>
              <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">worth $<%= items[i].price %></small>
                <% if (canAfford) { %>
                  <span class="badge bg-success">You can redeem this!</span>
                <% } else { %>
                  <small class="text-muted">need <%= items[i].points_cost - user.points %> more pts</small>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
