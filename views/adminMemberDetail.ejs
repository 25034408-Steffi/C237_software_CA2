<!DOCTYPE html>
<html>
<head>
    <title><%= member.name %> - Spending</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
  <%- include("partials/navbar") %>
  <div class="container mt-4">
    <%- include("partials/adminNav", { activeAdmin: 'members' }) %>

    <a href="/admin/members" class="btn btn-sm btn-outline-secondary mb-2"><i class="bi bi-arrow-left"></i> All members</a>

    <% const tierBadges = { classic: 'bg-secondary', gold: 'bg-warning text-dark', platinum: 'bg-dark' }; %>
    <h1><%= member.name %>
      <span class="badge <%= tierBadges[member.card_tier] %>"><%= member.card_tier %></span>
    </h1>
    <p class="text-muted">
      Card <%= member.card_id %> · Phone <%= member.phone_number %> · <%= member.points %> points
    </p>

    <!-- filter the spending list by date -->
    <form method="GET" action="/admin/members/<%= member.user_id %>" class="row g-2 align-items-end mb-3">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" class="form-control" name="from" value="<%= fromDate %>">
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" class="form-control" name="to" value="<%= toDate %>">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a href="/admin/members/<%= member.user_id %>" class="btn btn-outline-secondary">Clear</a>
      </div>
    </form>

    <div class="alert alert-light border">
      <strong><%= orders.length %></strong> order(s)
      <%= fromDate || toDate ? 'in this period' : 'in total' %> ·
      spent <strong>$<%= periodTotal.toFixed(2) %></strong>
    </div>

    <% if (orders.length === 0) { %>
      <div class="alert alert-info">No orders found for these dates.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Date</th>
            <th>Order #</th>
            <th>Type</th>
            <th>Status</th>
            <th>Total</th>
            <th class="text-end"></th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < orders.length; i++) { %>
            <tr>
              <td><%= orders[i].created_at.toLocaleString('en-SG', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
              <td><%= orders[i].order_id %></td>
              <td><%= orders[i].order_type === 'online' ? 'Online' : 'In restaurant' %></td>
              <td><%= orders[i].status %></td>
              <td>$<%= orders[i].total %></td>
              <td class="text-end">
                <%# click through to see the food and drinks inside this order %>
                <a href="/admin/members/<%= member.user_id %>/order/<%= orders[i].order_id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-list-ul"></i> View items
                </a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>
